# 服务端口
PORT=3000

# 允许的本地开发来源（逗号分隔，仅本地地址）
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:8000

# JSON 请求体大小限制
BODY_LIMIT=1mb

# AI 诊断服务配置
# provider 切换：mock（离线测试）或 qwen-vl（阿里云百炼通义千问 VL）
AI_PROVIDER=mock

# 阿里云百炼 DashScope 配置（qwen-vl 模式下必填）
# API Key 只放在 .env 中，切勿提交到代码库
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3-vl-flash
# 视觉诊断请求超时（毫秒）；默认 90 秒，范围 10–120 秒
DASHSCOPE_TIMEOUT_MS=90000

# AI 生图服务配置（诊断建议效果图，与诊断配置完全隔离）
# provider 标识：qwen-image（阿里云百炼通义千问生图），关闭则不调用生图
AI_IMAGE_PROVIDER=qwen-image
# 主生图编辑模型：wan2.6-image，支持输入原图进行编辑
QWEN_IMAGE_MODEL=wan2.6-image
# 生图专用 base url；未配置时会从 DASHSCOPE_BASE_URL 自动推导同一业务空间域名
# 阿里云百炼默认地址：https://dashscope.aliyuncs.com
# 北京业务空间专属域名：https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com
QWEN_IMAGE_BASE_URL=https://dashscope.aliyuncs.com
# 主模型超时后使用的降级模型
QWEN_IMAGE_TIMEOUT_MS=90000
QWEN_IMAGE_SUBMIT_TIMEOUT_MS=60000
QWEN_IMAGE_FALLBACK_MODEL=qwen-image-2.0
QWEN_IMAGE_FALLBACK_TIMEOUT_MS=60000
# 可选：最多配置 2 个你有权使用的公网 HTTPS 参考图 URL，仅用于学习风格
# 不要填第三方网站首页 URL；应填具体图片地址，并确认拥有使用权限
QWEN_STYLE_REFERENCE_URLS=
# 可选：项目级审美规范，会注入每次生图请求
QWEN_IMAGE_STYLE_PROFILE=苹果式克制、清晰、轻盈的现代产品设计；大留白；明确的信息层级；低饱和蓝白配色；细腻但不过度的玻璃质感；避免廉价模板感和装饰堆叠
# 生图请求超时（毫秒），默认 60s
QWEN_IMAGE_TIMEOUT_MS=60000

# 审美训练 AI 解析配置
# provider 标识：
# - none：完全不调用 AI，只返回本地解析（默认）
# - qwen-vl：复用 DashScope OpenAI 兼容端点
# - gemini：暂未实现，调用时自动降级为本地解析
# AI 只负责生成额外解释，不负责计分；失败时自动降级为本地解析
TRAINING_AI_PROVIDER=none
# 训练解析专用模型，未配置则降级到 DASHSCOPE_MODEL
# 可选更轻量的文本模型：qwen-plus / qwen-turbo
TRAINING_AI_MODEL=
# 训练解析请求超时（毫秒），默认 15s
TRAINING_AI_TIMEOUT_MS=15000
# 每个用户每天最多 AI 解析次数，默认 20
TRAINING_AI_DAILY_LIMIT=20

# 审美训练图库配置（密钥只放 server/.env，绝不放前端）
PEXELS_API_KEY=
PEXELS_API_BASE_URL=https://api.pexels.com/v1
PEXELS_TIMEOUT_MS=10000
